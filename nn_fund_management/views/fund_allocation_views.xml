<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nn_fund_allocation_form" model="ir.ui.view">
        <field name="name">nn.fund.allocation.form</field>
        <field name="model">nn.fund.allocation</field>
        <field name="arch" type="xml">
            <form string="Fund Allocation">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="oe_highlight" states="draft"/>
                    <button name="action_gm_approve" string="GM Approve" type="object" class="oe_highlight" states="submitted" groups="nn_fund_management.group_gm_approver"/>
                    <button name="action_md_approve" string="MD Approve" type="object" class="oe_highlight" states="gm_approved" groups="nn_fund_management.group_md_approver"/>
                    <button name="action_reject" string="Reject" type="object" states="submitted,gm_approved" groups="nn_fund_management.group_gm_approver,nn_fund_management.group_md_approver"/>
                    <button name="action_cancel" string="Cancel" type="object" states="draft,submitted,gm_approved,rejected" groups="nn_fund_management.group_fund_administrator"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,gm_approved,md_approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="fund_account_id" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="target_id" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="target_type" readonly="1"/>
                        </group>
                        <group>
                            <field name="amount" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="request_date" readonly="1"/>
                            <field name="requested_by_id" readonly="1"/>
                            <field name="company_id" invisible="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Purpose" name="purpose">
                            <field name="purpose" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_nn_fund_allocation_tree" model="ir.ui.view">
        <field name="name">nn.fund.allocation.tree</field>
        <field name="model">nn.fund.allocation</field>
        <field name="arch" type="xml">
            <tree string="Fund Allocations">
                <field name="name"/>
                <field name="fund_account_id"/>
                <field name="target_id"/>
                <field name="amount"/>
                <field name="request_date"/>
                <field name="state" widget="badge" decoration-info="state in ('submitted','gm_approved')" decoration-success="state == 'md_approved'"/>
            </tree>
        </field>
    </record>

    <record id="action_nn_fund_allocation" model="ir.actions.act_window">
        <field name="name">Fund Allocations</field>
        <field name="res_model">nn.fund.allocation</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
