<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="board_nn_fund_dashboard_form" model="ir.ui.view">
        <field name="name">nn.fund.dashboard.form</field>
        <field name="model">board.board</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form string="Fund Dashboard">
                <board style="1-2">
                    <column>
                        <action string="Projects &amp; Expense Balances" name="%(action_nn_project_expense_head)d"/>
                    </column>
                    <column>
                        <action string="Pending Allocations" name="%(action_nn_fund_allocation)d" domain="[('state', 'in', ('submitted', 'gm_approved'))]"/>
                        <action string="Pending Requisitions" name="%(action_nn_fund_requisition)d" domain="[('state', 'in', ('submitted', 'gm_approved'))]"/>
                    </column>
                </board>
            </form>
        </field>
    </record>

    <record id="action_nn_fund_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">board.board</field>
        <field name="view_mode">form</field>
        <field name="usage">menu</field>
        <field name="view_id" ref="board_nn_fund_dashboard_form"/>
    </record>

    <!-- Update the root menu to point to this action -->
    <record id="menu_nn_fund_dashboard" model="ir.ui.menu">
        <field name="action" ref="action_nn_fund_dashboard"/>
    </record>
</odoo>
