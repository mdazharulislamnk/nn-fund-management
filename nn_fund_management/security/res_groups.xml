<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Module Category -->
        <record id="module_category_nn_fund_management" model="ir.module.category">
            <field name="name">Fund Management</field>
            <field name="description">Helps you manage internal funds, projects, and expenses strictly.</field>
            <field name="sequence">10</field>
        </record>

        <!-- Group Fund User -->
        <record id="group_fund_user" model="res.groups">
            <field name="name">Fund User</field>
            <field name="category_id" ref="module_category_nn_fund_management"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Can view and create standard requests (allocation, requisition, transfer).</field>
        </record>

        <!-- Group Finance User -->
        <record id="group_finance_user" model="res.groups">
            <field name="name">Finance User</field>
            <field name="category_id" ref="module_category_nn_fund_management"/>
            <field name="implied_ids" eval="[(4, ref('group_fund_user'))]"/>
            <field name="comment">Can confirm incoming funds and handle bill processing.</field>
        </record>

        <!-- Group GM Approver -->
        <record id="group_gm_approver" model="res.groups">
            <field name="name">GM Approver</field>
            <field name="category_id" ref="module_category_nn_fund_management"/>
            <field name="implied_ids" eval="[(4, ref('group_fund_user'))]"/>
            <field name="comment">First-level approver.</field>
        </record>

        <!-- Group MD Approver -->
        <record id="group_md_approver" model="res.groups">
            <field name="name">MD Approver</field>
            <field name="category_id" ref="module_category_nn_fund_management"/>
            <field name="implied_ids" eval="[(4, ref('group_gm_approver'))]"/>
            <field name="comment">Final-level approver.</field>
        </record>

        <!-- Group Fund Administrator -->
        <record id="group_fund_administrator" model="res.groups">
            <field name="name">Fund Administrator</field>
            <field name="category_id" ref="module_category_nn_fund_management"/>
            <field name="implied_ids" eval="[(4, ref('group_md_approver')), (4, ref('group_finance_user'))]"/>
            <field name="comment">Full access to settings and overrides.</field>
        </record>

    </data>
</odoo>
