<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nn_project_expense_head_form" model="ir.ui.view">
        <field name="name">nn.project.expense.head.form</field>
        <field name="model">nn.project.expense.head</field>
        <field name="arch" type="xml">
            <form string="Project / Expense Head">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Project or Expense Head Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="target_type"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="total_allocated_fund" widget="monetary"/>
                            <field name="available_fund" widget="monetary" decoration-bf="1" decoration-success="1"/>
                            <field name="requisition_hold" widget="monetary"/>
                            <field name="transfer_hold" widget="monetary"/>
                            <field name="approved_unspent_amount" widget="monetary"/>
                            <field name="total_spent_amount" widget="monetary"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_nn_project_expense_head_tree" model="ir.ui.view">
        <field name="name">nn.project.expense.head.tree</field>
        <field name="model">nn.project.expense.head</field>
        <field name="arch" type="xml">
            <tree string="Projects / Expense Heads">
                <field name="name"/>
                <field name="target_type"/>
                <field name="total_allocated_fund"/>
                <field name="available_fund"/>
                <field name="total_spent_amount"/>
            </tree>
        </field>
    </record>

    <record id="action_nn_project_expense_head" model="ir.actions.act_window">
        <field name="name">Projects &amp; Expense Heads</field>
        <field name="res_model">nn.project.expense.head</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
